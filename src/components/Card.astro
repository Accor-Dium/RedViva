---
import { Image } from "astro:assets";
import { LinkSimpleIcon } from "@phosphor-icons/react";
import { RESIZE_CARD_CONSTANTS } from "../constants/components/layout";
import { RATIO_DIMENSIONS, RATIO_MAP } from "../constants/components/tarjetas";
import type { CardRatio } from "../types/directorio/InterfaceTarjInformativas";
import { TiltCard } from "./general/TiltCard";

interface Props {
  src: string;
  alt?: string;
  ratio?: CardRatio;
  width?: string;
  href?: string;
  tarjetaId?: number;
  class?: string;
  loading?: "lazy" | "eager";
}

const {
  src,
  alt = RESIZE_CARD_CONSTANTS.DEFAULT_ALT_TEXT,
  ratio = RESIZE_CARD_CONSTANTS.DEFAULT_RATIO,
  width = RESIZE_CARD_CONSTANTS.DEFAULT_WIDTH,
  href,
  tarjetaId,
  class: className = "",
  loading = "lazy",
} = Astro.props as Props;

const containerWidth = width === "100%" ? "w-full" : "";
const ratioClass = RATIO_MAP[ratio] || RATIO_MAP["1:1"];
const imageDimensions = RATIO_DIMENSIONS[ratio] || RATIO_DIMENSIONS["1:1"];
---

<TiltCard
  client:load
  className={`${containerWidth}  p-1 md:p-3  bg-white/10 backdrop-blur-md rounded-2xl overflow-hidden leading-none break-inside-avoid shadow-lg border border-white/20 transition-shadow ${className}`}
>
    <div class={`relative w-full ${ratioClass} overflow-hidden rounded-xl`}>
      <Image
        src={src}
        alt={alt}
        width={imageDimensions.width}
        height={imageDimensions.height}
        loading={loading}
        decoding="async"
        class="h-full w-full object-cover block"
      />
    </div>
    {
      href && (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          data-tarjeta-id={tarjetaId}
          class="flex items-center justify-center gap-2 px-4 pt-2 text-center text-white font-semibold transition-colors tarjeta-link"
        >
          <LinkSimpleIcon size={18} />
          {RESIZE_CARD_CONSTANTS.BUTTON_TEXT}
        </a>
      )
    }
</TiltCard>

<script>
  import { initTarjetaTracking } from '../utils/tarjetaTracker';

  // Inicializar tracking de tarjetas cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', () => {
    initTarjetaTracking();
  });
</script>
