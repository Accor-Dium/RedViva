---
interface Props {
    color?: "purple" | "pink" | "red" | "green" | "blue"
    size?: "sm" | "md" | "lg"
    href?: string
    [key: string]: unknown
}

const { color = "purple", size = "md", href, ...rest } = Astro.props

const colors = {
    purple: "bg-purple-300 hover:bg-purple-400 text-purple-900",
    pink:   "bg-pink-300   hover:bg-pink-400   text-pink-900",
    red:    "bg-red-400    hover:bg-red-500     text-white",
    green:  "bg-green-400  hover:bg-green-500   text-white",
    blue:   "bg-blue-400   hover:bg-blue-500    text-white",
}

const sizes = {
    sm: "text-xs px-3 py-1",
    md: "text-sm px-5 py-2",
    lg: "text-base px-7 py-3",
}

const classes = `rounded-md font-semibold cursor-pointer transition-colors ${colors[color]} ${sizes[size]}`
---

{href
    ? <a href={href} class={classes} {...rest}><slot /></a>
    : <button class={classes} {...rest}><slot /></button>
}
