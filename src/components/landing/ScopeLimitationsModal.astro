---
import Button from "../general/Button.astro";

const styles = {
  overlay:
    "fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4 backdrop-blur-lg",
  content:
    "w-full max-w-2xl rotate-3 bg-white p-6 shadow-2xl md:px-26 md:py-20",
  title: "text-3xl font-bold text-black text-center pb-4",
  paragraph:
    "mt-3 text-sm leading-tight text-gray-700 md:text-base text-justify",
  actions: "mt-6 flex justify-center",
};
---

<div
  id="scope-limitations-modal"
  class={styles.overlay}
  role="dialog"
  aria-modal="true"
  aria-labelledby="scope-limitations-title"
>
  <div class={styles.content}>
    <div class=" -rotate-3">
      <h2 id="scope-limitations-title" class={styles.title}>
        DECLARACIÓN DE ALCANCE Y LIMITACIONES
      </h2>
      <p class={styles.paragraph}>
        Este instituto recibe información de manera preventiva como parte de su
        labor de orientación dentro del ámbito escolar.
      </p>
      <p class={styles.paragraph}>
        Este reporte no constituye una denuncia formal ni sustituye los
        procedimientos legales correspondientes. En caso de requerirse una
        acción legal o denuncia formal, deberá presentarse directamente ante la
        autoridad competente.
      </p>
      <p class={styles.paragraph}>
        La institución actúa únicamente como canal de prevención y recepción de
        información, sin determinar responsabilidades ni emitir juicios sobre
        los hechos señalados.
      </p>
      <div class={styles.actions}>
        <Button color="red" size="md" id="scope-limitations-accept">
          Entendido, continuar
        </Button>
      </div>
    </div>
  </div>
</div>

<script>
  import { animate } from "motion/mini";

  (() => {
    const storageKey = "contacto_scope_limitations_seen_v1";
    const modal = document.getElementById("scope-limitations-modal");
    const acceptButton = document.getElementById("scope-limitations-accept");
    const modalContent = modal?.firstElementChild;

    if (!modal || !acceptButton || !modalContent) return;

    let isClosing = false;

    const openModal = () => {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";

      animate(modal, { opacity: [0, 1] }, { duration: 0.25, ease: "easeOut" });
      animate(
        modalContent,
        { opacity: [0, 1], scale: [0.96, 1] },
        { duration: 0.3, ease: "easeOut" }
      );
    };

    let hasSeenNotice = false;
    try {
      hasSeenNotice = localStorage.getItem(storageKey) === "true";
    } catch {
      // Treat as "not seen yet" if localStorage is unavailable
    }
    if (!hasSeenNotice) {
      openModal();
    }

    const closeModal = async () => {
      if (isClosing) return;
      isClosing = true;

      await Promise.all([
        animate(modal, { opacity: [1, 0] }, { duration: 0.2, ease: "easeIn" }).finished,
        animate(
          modalContent,
          { opacity: [1, 0], scale: [1, 0.98] },
          { duration: 0.2, ease: "easeIn" }
        ).finished,
      ]);

      modal.classList.remove("flex");
      modal.classList.add("hidden");
      document.body.style.overflow = "";
      isClosing = false;
    };

    acceptButton.addEventListener("click", () => {
      try {
        localStorage.setItem(storageKey, "true");
      } catch {
        // Skip persistence if localStorage is unavailable
      }
      void closeModal();
    });
  })();
</script>
