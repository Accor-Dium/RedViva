---
import { Image } from 'astro:assets';
import NavbarScroll from "./general/NavbarScroll";

const navLinks = [
  { label: "Red Viva", href: "/landing/conocete" },
  { label: "Conoce tus Derechos", href: "/landing/directorio" },
  { label: "Contacto", href: "/landing/contacto" },
];

const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-30 left-0 right-0 bg-transparent transition-all duration-300" id="navbar">
  <NavbarScroll client:load />
  <div class="max-w-6xl mx-auto sm:px-8 py-4 flex flex-col md:flex-row justify-center items-center relative gap-8 w-full">
    <div class="w-48 h-32 z-40 lg:w-64 lg:h-40 bg-white rotate-3 absolute -top-10 md:left-0">
      <Image
        src="/logos/logo_redviva.png"
        alt="Logo Instituto"
        width={160}
        height={80}
        loading="eager"
        fetchpriority="high"
        class="absolute mt-2 top-1/2 -translate-y-1/2 left-1/2 -translate-x-1/2 -rotate-3"
      />
    </div>
    <ul class="flex z-50 gap-0 sm:gap-2 lg:gap-14 list-none m-0 p-0 mt-20 md:mt-0 w-full justify-center">
      {
        navLinks.map((link) => {
          const isActive = currentPath === link.href;
          return (
            <li>
              <a
                href={link.href}
                class={`font-medium transition-all hover:text-white duration-300 border-b-2 border-transparent text-sm md:text-base py-2 px-3 md:py-1 md:px-2 ${
                  isActive
                    ? 'text-white border-white'
                    : 'text-white/70 hover:text-white hover:border-white'
                }`}
              >
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</nav>