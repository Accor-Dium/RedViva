---
import { Image } from 'astro:assets';
---

<div class=" hidden lg:flex flex-col justify-center items-center gap-2 my-12 flex-wrap absolute -top-10 -right-5 -rotate-2">
  <div class="w-50 h-24 bg-white  flex justify-center items-center shadow-lg mr-4">
    <Image
      src="/logos/logo_redviva.png"
      alt="Logo Instituto"
      width={100}
      height={40}
      loading="eager"
      fetchpriority="high"
      class="w-40 h-auto"
    />
  </div>
  
  <div class="w-50 h-24 bg-white  flex justify-center items-center shadow-lg">
    <Image
      src="/logos/logo_ayuntamiento.png"
      alt="Logo Ayuntamiento"
      width={160}
      height={96}
      loading="eager"
      fetchpriority="high"
      class="w-40 h-auto"
    />
  </div>
</div>
