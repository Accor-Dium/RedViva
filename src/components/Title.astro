---
interface Props {
  name: string;
  size?: "sm" | "md" | "lg" | "xl";
  color?: string;
}

const { name, size = "lg", color = "text-white" } = Astro.props as Props;

const sizeClasses = {
  sm: "text-2xl md:text-3xl",
  md: "text-3xl md:text-4xl",
  lg: "text-4xl md:text-6xl",
  xl: "text-5xl md:text-7xl",
};
---

<h2 class={`font-itcgothic ${sizeClasses[size]} ${color} wrap-break-word`}>
  {name}
</h2>

