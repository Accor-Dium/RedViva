---
import {
  ADMIN_NAV_LINKS,
  ADMIN_SIDEBAR_CONSTANTS,
  ADMIN_COLORS,
} from "@/constants/components/admin.ts";
import type { AdminNavLink } from "@/constants/components/admin.ts";

const currentPath = Astro.url.pathname;

const styles = {
  menuToggle: [
    "fixed top-4 left-4 z-50 p-2 rounded-md",
    "bg-white border border-gray-200 shadow-md",
    "text-gray-700 hover:bg-gray-100",
    "transition-colors lg:hidden",
  ].join(" "),

  menuIcon: "w-6 h-6",

  overlay: [
    "fixed inset-0 z-40",
    "bg-black/40 backdrop-blur-sm",
    "opacity-0 pointer-events-none",
    "transition-opacity duration-300",
    "lg:hidden",
  ].join(" "),

  sidebar: [
    "fixed top-0 left-0 z-50",
    "h-full w-56",
    ADMIN_COLORS.sidebar.bg,
    `border-r ${ADMIN_COLORS.sidebar.border}`,
    "shadow-lg",
    "flex flex-col",
    "-translate-x-full transition-transform duration-300",
    "lg:translate-x-0",
  ].join(" "),

  header: [
    "flex items-center gap-3",
    "px-5 py-6",
    `border-b ${ADMIN_COLORS.sidebar.border}`,
  ].join(" "),

  logoImg: "w-10 h-10 object-contain",

  logoText: [
    "text-sm font-bold tracking-wide",
    ADMIN_COLORS.sidebar.logo,
  ].join(" "),

  nav: "flex flex-col gap-1 mt-4 px-3 flex-1",

  linkBase: [
    "flex items-center gap-3",
    "px-4 py-2.5 rounded-lg",
    "text-sm font-medium",
    "transition-colors duration-200",
  ].join(" "),

  linkActive: [
    ADMIN_COLORS.sidebar.bgActive,
    ADMIN_COLORS.sidebar.textActive,
  ].join(" "),

  linkInactive: [
    ADMIN_COLORS.sidebar.textInactive,
    ADMIN_COLORS.sidebar.bgHover,
    "hover:text-gray-800",
  ].join(" "),

  linkIcon: "w-5 h-5",

  collapseBtn: [
    "flex items-center gap-3",
    "px-5 py-4",
    `border-t ${ADMIN_COLORS.sidebar.border}`,
    "text-sm font-medium text-gray-500",
    "hover:text-gray-800 hover:bg-gray-50",
    "transition-colors",
  ].join(" "),

  collapseIcon: "w-5 h-5",

  closeBtn: [
    "p-1 rounded-md",
    "text-gray-400 hover:text-gray-700 hover:bg-gray-100",
    "transition-colors lg:hidden",
  ].join(" "),

  closeIcon: "w-5 h-5",
} as const;

const ICON_PATHS: Record<AdminNavLink["icon"], string> = {
  dashboard: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z",
  denuncias: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
  tarjetas: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10",
} as const;
---

<button id="admin-menu-toggle" class={styles.menuToggle} aria-label={ADMIN_SIDEBAR_CONSTANTS.MENU_BUTTON_LABEL}>
  <svg class={styles.menuIcon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>
<div id="admin-sidebar-overlay" class={styles.overlay}></div>

<aside id="admin-sidebar" class={styles.sidebar}>

  <div class={styles.header}>
    <img src="/logos/buttlefly.ico" alt="Logo" class={styles.logoImg} />
    <span class={styles.logoText}>{ADMIN_SIDEBAR_CONSTANTS.TITLE}</span>
    <button id="admin-menu-close" class={`${styles.closeBtn} ml-auto`} aria-label="Cerrar menú">
      <svg class={styles.closeIcon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav class={styles.nav}>
    {ADMIN_NAV_LINKS.map((link) => {
      const isActive = currentPath === link.href;
      const linkClass = `${styles.linkBase} ${isActive ? styles.linkActive : styles.linkInactive}`;

      return (
          <a href={link.href} class={linkClass}>
            <svg class={styles.linkIcon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ICON_PATHS[link.icon]} />
            </svg>
            {link.label}
          </a>
      );
    })}
  </nav>

  <button id="admin-collapse-btn" class={styles.collapseBtn}>
    <svg class={styles.collapseIcon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
    {ADMIN_SIDEBAR_CONSTANTS.COLLAPSE_LABEL}
  </button>
</aside>

<script>
  function initAdminSidebar(): void {
    const toggle = document.getElementById("admin-menu-toggle");
    const close = document.getElementById("admin-menu-close");
    const sidebar = document.getElementById("admin-sidebar");
    const overlay = document.getElementById("admin-sidebar-overlay");

    if (!toggle || !close || !sidebar || !overlay) return;

    function openSidebar(): void {
      sidebar!.classList.remove("-translate-x-full");
      sidebar!.classList.add("translate-x-0");
      overlay!.classList.remove("opacity-0", "pointer-events-none");
      overlay!.classList.add("opacity-100", "pointer-events-auto");
    }

    function closeSidebar(): void {
      sidebar!.classList.add("-translate-x-full");
      sidebar!.classList.remove("translate-x-0");
      overlay!.classList.add("opacity-0", "pointer-events-none");
      overlay!.classList.remove("opacity-100", "pointer-events-auto");
    }

    toggle.addEventListener("click", openSidebar);
    close.addEventListener("click", closeSidebar);
    overlay.addEventListener("click", closeSidebar);
  }

  document.addEventListener("astro:page-load", initAdminSidebar);
</script>