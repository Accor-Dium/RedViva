---
import {
  ADMIN_NAV_LINKS,
  ADMIN_SIDEBAR_CONSTANTS,
  ADMIN_COLORS,
  ADMIN_ICON_PATHS
} from "@/constants/components/admin.ts";
import type { AdminNavLink } from "@/constants/components/admin.ts";

const currentPath = Astro.url.pathname;

const styles = {
  menuToggle: [
    "fixed top-4 left-4 z-50 p-2 rounded-md",
    "bg-white border border-gray-200 shadow-md",
    "text-gray-700 hover:bg-gray-100",
    "transition-colors lg:hidden",
  ].join(" "),

  menuIcon: "w-6 h-6",

  overlay: [
    "fixed inset-0 z-40",
    "bg-black/40 backdrop-blur-sm",
    "opacity-0 pointer-events-none",
    "transition-opacity duration-300",
    "lg:hidden",
  ].join(" "),

  sidebar: [
    "fixed top-0 left-0 z-50",
    "h-full w-56",
    ADMIN_COLORS.sidebar.bg,
    `border-r ${ADMIN_COLORS.sidebar.border}`,
    "shadow-lg",
    "flex flex-col",
    "-translate-x-full transition-all duration-300",
    "lg:translate-x-0",
  ].join(" "),

  header: [
    "flex items-center gap-3",
    "px-5 py-6",
    `border-b ${ADMIN_COLORS.sidebar.border}`,
    "overflow-hidden",
  ].join(" "),

  logoImg: "w-10 h-10 object-contain shrink-0",

  logoText: [
    "text-sm font-bold tracking-wide whitespace-nowrap",
    "transition-opacity duration-300",
    ADMIN_COLORS.sidebar.logo,
  ].join(" "),

  nav: "flex flex-col gap-1 mt-4 px-3 flex-1",

  linkBase: [
    "flex items-center gap-3",
    "px-4 py-2.5 rounded-lg",
    "text-sm font-medium",
    "transition-colors duration-200",
    "overflow-hidden whitespace-nowrap",
  ].join(" "),

  linkActive: [
    ADMIN_COLORS.sidebar.bgActive,
    ADMIN_COLORS.sidebar.textActive,
  ].join(" "),

  linkInactive: [
    ADMIN_COLORS.sidebar.textInactive,
    ADMIN_COLORS.sidebar.bgHover,
    "hover:text-gray-800",
  ].join(" "),

  linkIcon: "w-5 h-5 shrink-0 mr-2",

  linkText: "transition-opacity duration-300",

  collapseBtn: [
    "flex items-center gap-6",
    "px-6 py-4",
    `border-t ${ADMIN_COLORS.sidebar.border}`,
    "text-sm font-medium text-gray-500",
    "hover:text-gray-800 hover:bg-gray-50",
    "transition-colors",
    "overflow-hidden whitespace-nowrap",
  ].join(" "),

  collapseIcon: "w-5 h-5 shrink-0 transition-transform duration-300",

  collapseText: "transition-opacity duration-300",

  closeBtn: [
    "p-1 rounded-md ml-auto",
    "text-gray-400 hover:text-gray-700 hover:bg-gray-100",
    "transition-colors lg:hidden",
  ].join(" "),

  closeIcon: "w-5 h-5",
} as const;

---

<button id="admin-menu-toggle" class={styles.menuToggle} aria-label={ADMIN_SIDEBAR_CONSTANTS.MENU_BUTTON_LABEL}>
  <svg class={styles.menuIcon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>

<div id="admin-sidebar-overlay" class={styles.overlay}></div>

<aside id="admin-sidebar" class={styles.sidebar}>

  <div class={styles.header}>
    <img src="/logos/buttlefly.ico" alt="Logo" class={styles.logoImg} />
    <span class={`${styles.logoText} sidebar-label`}>{ADMIN_SIDEBAR_CONSTANTS.TITLE}</span>
    <button id="admin-menu-close" class={styles.closeBtn} aria-label="Cerrar menú">
      <svg class={styles.closeIcon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav class={styles.nav}>
    {ADMIN_NAV_LINKS.map((link) => {
      const isActive = currentPath === link.href;
      const linkClass = `${styles.linkBase} ${isActive ? styles.linkActive : styles.linkInactive}`;

      return (
          <a href={link.href} class={linkClass} title={link.label}>
            <svg class={styles.linkIcon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ADMIN_ICON_PATHS[link.icon]} />
            </svg>
            <span class={`${styles.linkText} sidebar-label`}>{link.label}</span>
          </a>
      );
    })}
  </nav>

  <button
      id="admin-collapse-btn"
      class={styles.collapseBtn}
      aria-label={ADMIN_SIDEBAR_CONSTANTS.COLLAPSE_LABEL}
  >
    <svg id="admin-collapse-icon" class={styles.collapseIcon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
    <span class={`${styles.collapseText} sidebar-label`}>{ADMIN_SIDEBAR_CONSTANTS.COLLAPSE_LABEL}</span>
  </button>
</aside>

<script>
  const EXPANDED_WIDTH = "w-56";
  const COLLAPSED_WIDTH = "w-18";

  function initAdminSidebar(): void {
    const toggle = document.getElementById("admin-menu-toggle");
    const close = document.getElementById("admin-menu-close");
    const sidebar = document.getElementById("admin-sidebar");
    const overlay = document.getElementById("admin-sidebar-overlay");
    const collapseBtn = document.getElementById("admin-collapse-btn");
    const collapseIcon = document.getElementById("admin-collapse-icon");
    const labels = sidebar?.querySelectorAll(".sidebar-label");

    if (!toggle || !close || !sidebar || !overlay || !collapseBtn || !collapseIcon || !labels) return;

    function openSidebar(): void {
      sidebar!.classList.remove("-translate-x-full");
      sidebar!.classList.add("translate-x-0");
      overlay!.classList.remove("opacity-0", "pointer-events-none");
      overlay!.classList.add("opacity-100", "pointer-events-auto");
    }

    function closeSidebar(): void {
      sidebar!.classList.add("-translate-x-full");
      sidebar!.classList.remove("translate-x-0");
      overlay!.classList.add("opacity-0", "pointer-events-none");
      overlay!.classList.remove("opacity-100", "pointer-events-auto");
    }

    function applyCollapsedState(collapsed: boolean): void {
      if (collapsed) {
        sidebar!.classList.remove(EXPANDED_WIDTH);
        sidebar!.classList.add(COLLAPSED_WIDTH);
        collapseIcon!.classList.add("rotate-180");
        labels!.forEach((label) => {
          label.classList.add("opacity-0", "pointer-events-none");
        });
      } else {
        sidebar!.classList.remove(COLLAPSED_WIDTH);
        sidebar!.classList.add(EXPANDED_WIDTH);
        collapseIcon!.classList.remove("rotate-180");
        labels!.forEach((label) => {
          label.classList.remove("opacity-0", "pointer-events-none");
        });
      }
    }

    function toggleCollapse(): void {
      const isCurrentlyCollapsed = sidebar!.classList.contains(COLLAPSED_WIDTH);
      applyCollapsedState(!isCurrentlyCollapsed);
    }

    toggle.addEventListener("click", openSidebar);
    close.addEventListener("click", closeSidebar);
    overlay.addEventListener("click", closeSidebar);
    collapseBtn.addEventListener("click", toggleCollapse);
  }

  document.addEventListener("astro:page-load", initAdminSidebar);
</script>