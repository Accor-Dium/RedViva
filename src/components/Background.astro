---
import { GRADIENT_COLORS } from '../constants/components/layout';

interface Props {
    gradientFrom?: string;
    gradientTo?: string;
    palette?: 'conocete' | 'directorio' | 'contacto';
}

const { 
    palette = 'conocete',
    gradientFrom,
    gradientTo,
} = Astro.props as Props;

const from = gradientFrom || GRADIENT_COLORS[palette].from;
const to = gradientTo || GRADIENT_COLORS[palette].to;

function hexToNumber(hex: string): number {
    return parseInt(hex.replace('#', ''), 16);
}

const waveColor = hexToNumber(from);
---

<div id="vanta-background" data-color={`0x${from.replace('#', '')}`}></div>

<script>
  declare global {
    var THREE: any;
    var VANTA: any;
  }

  let vantaInstance: any = null;
  
  function loadScript(src: string) {
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = src;
      script.onload = resolve;
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  async function initVanta() {
    // Destruir instancia anterior si existe
    if (vantaInstance) {
      vantaInstance.destroy();
      vantaInstance = null;
    }

    // Cargar scripts solo si no están disponibles
    if (typeof THREE === 'undefined') {
      await loadScript('https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js');
    }
    if (typeof VANTA === 'undefined') {
      await loadScript('https://cdnjs.cloudflare.com/ajax/libs/vanta/0.5.24/vanta.waves.min.js');
    }

    const element = document.getElementById('vanta-background');
    if (element) {
      const colorFromData = element.getAttribute('data-color');
      const waveColor = colorFromData ? parseInt(colorFromData) : 0;
      
      vantaInstance = VANTA.WAVES({
        el: element,
        mouseControls: false,
        touchControls: true,
        gyroControls: false,
        minHeight: 200.00,
        minWidth: 200.00,
        scale: 1.00,
        scaleMobile: 1.00,
        color: waveColor,
        shininess: 1.00,
        waveSpeed: 0.20
      });
    }
  }

  // Esperar a que el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initVanta);
  } else {
    initVanta();
  }

  // Limpiar y reiniciar en transiciones de Astro
  document.addEventListener('astro:after-swap', initVanta);
</script>

<style>
  #vanta-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
  }
</style>