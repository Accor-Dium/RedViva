---
import "../../styles/global.css";
import { ClientRouter } from "astro:transitions";
import AdminSidebar from "../../components/admin/AdminSidebar.astro";
import { ADMIN_COLORS } from "@/constants/components/admin.ts";

interface Props {
  title: string;
}

const { title } = Astro.props as Props;

const styles = {
  body: `min-h-screen ${ADMIN_COLORS.content.bg} ${ADMIN_COLORS.content.text}`,
  main: [
    "min-h-screen",
    "px-6 py-8",
    "lg:pl-62",
  ].join(" "),
} as const;
---

<html lang="es">
<head>
  <ClientRouter />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <link rel="icon" type="image/svg+xml" href="/logos/buttlefly.ico" />
  <title>{title}</title>
  <style>
    body {
      margin: 0;
      overflow-x: hidden;
      position: relative;
    }
  </style>
</head>
<body class={styles.body}>
<AdminSidebar />
<main class={styles.main}>
  <slot />
</main>
</body>
</html>