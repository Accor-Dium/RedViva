---
import "../../styles/global.css";
import AdminSidebar from "../../components/admin/AdminSidebar.astro";
import HeadMeta from "../layouts/HeadMeta.astro";
import { ADMIN_COLORS } from "../../constants/components/admin.ts";

interface Props {
  title: string;
}

const { title } = Astro.props as Props;

const styles = {
  body: `min-h-screen ${ADMIN_COLORS.content.bg} ${ADMIN_COLORS.content.text}`,
  main: [
    "min-h-screen",
    "px-6 py-8",
    "transition-[padding-left] duration-300",
    "lg:pl-62",
  ].join(" "),
} as const;
---

<html lang="es">
<head>
  <HeadMeta title={title} />
  <style is:inline>
    body {
      margin: 0;
      overflow-x: hidden;
      position: relative;
    }
  </style>
</head>
<body class={styles.body}>
<AdminSidebar />
<main id="admin-main" class={styles.main}>
  <slot />
</main>
</body>
</html>

<script>
  const COLLAPSED_WIDTH = "w-18";
  const PL_EXPANDED = "lg:pl-62";
  const PL_COLLAPSED = "lg:pl-24";

  function initAdminMain(): void {
    const main = document.getElementById("admin-main");
    const sidebar = document.getElementById("admin-sidebar");
    if (!main || !sidebar) return;

    const observer = new MutationObserver(() => {
      const isCollapsed = sidebar.classList.contains(COLLAPSED_WIDTH);
      if (isCollapsed) {
        main.classList.remove(PL_EXPANDED);
        main.classList.add(PL_COLLAPSED);
      } else {
        main.classList.remove(PL_COLLAPSED);
        main.classList.add(PL_EXPANDED);
      }
    });

    observer.observe(sidebar, { attributes: true, attributeFilter: ["class"] });
  }

  document.addEventListener("astro:page-load", initAdminMain);
</script>