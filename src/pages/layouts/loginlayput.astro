---
// src/layouts/loginlayput.astro
const { title } = Astro.props;
import "../../styles/global.css";; 
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
  </head>
  <body class="m-0 p-0 font-['Inter'] antialiased bg-[#4A00E0] h-full">
    <slot /> 
  </body>
</html>

<style is:global>
  html, body {
    height: 100vh; 
    margin: 0;
    overflow: hidden;
  }
</style>