---
import Layout from "../layouts/Layout.astro"
import Title from "../../components/Title.astro"
import { GRADIENT_COLORS } from "../../constants/components/layout"
import { TITLE, TITLE2, TITLE3, TITLE4, TITLE5, TEXTO1, TEXTO2, TEXTO3, TEXTO4, IMAGE1, IMAGE2, OBJETIVOS } from "../../constants/pages/conocete"
import { Image } from "astro:assets"

const styles = {
  main: "min-h-screen w-full flex flex-col gap-6 justify-start px-6  md:pt-14 text-white",
  article: "grid grid-cols-1 md:grid-cols-4 gap-6 md:gap-8 text-lg",
  textSection: "order-2 md:order-1 md:col-span-2 flex items-center justify-center py-4",
  imageContainer: "order-1 md:order-2 md:col-span-2 flex items-center justify-center",
  fullWidthSection: "order-3 md:col-span-4 flex flex-col gap-3 py-4",
  sideImageContainer: "order-5 md:order-4 flex items-start justify-center py-4",
  contentSection: "order-4 md:order-5 md:col-span-3 flex flex-col gap-4 py-4",
  halfSection: "order-6 md:col-span-2 md:row-span-2 md:row-start-9 flex flex-col",
  halfSectionRight: "order-7 md:col-span-2 md:row-span-2 md:col-start-3 md:row-start-9",
  image: "w-full h-full object-contain rounded-lg",
  imageAuto: "w-full h-auto object-contain rounded-lg",
  list: "list-disc list-inside space-y-2",
  listItem: "text-white",
}
---

<Layout gradientFrom={GRADIENT_COLORS.conocete.from} gradientTo={GRADIENT_COLORS.conocete.to}>
  <main class={styles.main}>
    <Title name={TITLE}/>
    <article class={styles.article}>
      <div class={styles.textSection}>
        <p>
          {TEXTO1}
        </p>
      </div>
      <div class={styles.imageContainer}>
        <Image
          src={IMAGE1}
          alt="RedViva1"
          width={2048}
          height={1365}
          fetchpriority="high"
          loading="eager"
          class={styles.image}
        />
      </div>
      <div class={styles.fullWidthSection}>
        <Title name={TITLE2} size="sm"/>
        <p>
          {TEXTO2}
        </p>
      </div>
      <div class={styles.sideImageContainer}>
        <Image 
          src={IMAGE2}
          alt="RedViva2"
          width={408}
          height={612}
          fetchpriority="high"
          loading="lazy"
          class={styles.imageAuto}
        />
      </div>
      <div class={styles.contentSection}>
        <Title name={TITLE3} size="sm"/>
        <ul class={styles.list}>
          {Object.entries(OBJETIVOS).map(([key, objetivo]) => (
            <li class={styles.listItem}>{objetivo}</li>
          ))}
        </ul>
      </div>
      <div class={styles.halfSection}>
        <Title name={TITLE4} size="sm"/>
        <p>
          {TEXTO3}
        </p>
      </div>
      <div class={styles.halfSectionRight}>
        <Title name={TITLE5} size="sm"/>
        <p>
          {TEXTO4}
        </p>
      </div>
    </article>
  </main>
</Layout>