---
// Aquí va el java script
import Layout from "../layouts/Layout.astro"
import { GRADIENT_COLORS } from "../../constants/components/layout"
import Title from "../../components/Title.astro"
import ImageGallery from "../../components/layout/ImageGallery.astro"
import { prisma } from "../../lib/prisma"
import { getImageRatioFromCloudinary } from "../../utils/ratio"

const styles = {
    main: ""
}

// Obtener tarjetas informativas desde la base de datos
const tarjetas = await prisma.tarj_informativas.findMany({
    orderBy: { fecha_creacion: "desc" },
})

// Mapear tarjetas a formato de ImageGallery
const imageItems = await Promise.all(
    tarjetas.map(async (tarjeta) => {
        const src = tarjeta.imagen || "https://via.placeholder.com/400x400?text=Sin+Imagen"
        const ratio = await getImageRatioFromCloudinary(tarjeta.imagen)

        return {
            id: `tarjeta-${tarjeta.id}`,
            src,
            alt: tarjeta.descripcion,
            ratio,
            href: tarjeta.enlace,
        }
    })
)
---

<Layout gradientFrom={GRADIENT_COLORS.directorio.from} gradientTo={GRADIENT_COLORS.directorio.to}>
    <main class={styles.main}>
        <Title name="CONOCE TUS DERECHOS" />
        <div class="mt-12 w-full">
            <ImageGallery images={imageItems} />
        </div>
    </main>
</Layout>