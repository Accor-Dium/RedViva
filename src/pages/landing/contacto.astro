---
import Layout from "../layouts/Layout.astro"
import { GRADIENT_COLORS } from "../../constants/components/layout"
import { ContactoSection } from "../../components/landing/ContactoSection"

const styles = {
    main: "w-full flex items-center justify-center overflow-hidden md:overflow-visible"
}
---

<Layout gradientFrom={GRADIENT_COLORS.contacto.from} gradientTo={GRADIENT_COLORS.contacto.to}>
    <main class={styles.main}>
        <div class="bg-white shadow-lg mt-8 p-10 max-w-4xl w-full -rotate-3 flex flex-col items-center">
            <div class="rotate-3 w-full flex flex-col items-center mt-5 mb-5 gap-5">
                <ContactoSection client:load />
            </div>
        </div>
    </main>
</Layout>