---
// Aquí va el java script
import Layout from "../layouts/Layout.astro"
import { GRADIENT_COLORS } from "../../constants/components/layout"
import Title from "../../components/Title.astro"
import Button from "../../components/general/Button.astro"
import { TITULO1, TITULO2, PARRAFO1, PARRAFO2, BUTTON_TEXT, WHATSAPP_IMG } from "../../constants/pages/contacto"
import { Image } from "astro:assets"

const styles = {
    main: "w-full flex items-center justify-center"
}
---

<Layout gradientFrom={GRADIENT_COLORS.contacto.from} gradientTo={GRADIENT_COLORS.contacto.to}>
    <main class={styles.main}>
        <div class="bg-white shadow-lg mx-auto mt-8 p-10 max-w-4xl w-full -rotate-3 flex flex-col items-center">
            <div class="rotate-3 w-full flex flex-col items-center mt-5 mb-5 gap-5">
                <h1>
                    <Title name={TITULO1} size="sm" color="text-black"/>
                </h1>
                <p>
                    {PARRAFO1}
                </p>
                <Image 
                    src={WHATSAPP_IMG}
                    alt="Whathsapp"
                    width={336}
                    height={70}
                />
                <h1>
                    <Title name={TITULO2} size="sm" color="text-black"/>
                </h1>
                <p>
                    {PARRAFO2}
                </p>
                <Button color="red">
                    {BUTTON_TEXT}
                </Button>
            </div>
        </div>
    </main>
</Layout>